    "# cau 1\n",
    "def ex1():\n",
    "    f_a = 3*x**4 - 16*x**3 + 18*x**2 - 9\n",
    "    f_b = (x + 2)/(2*x**2)\n",
    "    f_c = -x**2/3 + x**2 + 3*x + 4\n",
    "    f_d = (5*x**2 + 5)/x\n",
    "    \n",
    "    print(\"Cau 1a:\", sp.solve(sp.diff(f_a, x), x))\n",
    "    print(\"Cau 1b:\", sp.solve(sp.diff(f_b, x), x))\n",
    "    print(\"Cau 1c:\", sp.solve(sp.diff(f_c, x), x))\n",
    "    print(\"Cau 1d:\", sp.solve(sp.diff(f_d, x), x))\n",
    "\n",
    "ex1()"
   ]
