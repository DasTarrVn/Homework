    "# cau 2\n",
    "def ex2(f, name):\n",
    "    df = sp.diff(f, x)\n",
    "    df2 = sp.diff(f, x, 2)\n",
    "    cps = sp.solve(df, x)\n",
    "    res = []\n",
    "    for cp in cps:\n",
    "        val = df2.subs(x, cp)\n",
    "        if val > 0: res.append(f\"x={cp} (Cuc tieu)\")\n",
    "        elif val < 0: res.append(f\"x={cp} (Cuc dai)\")\n",
    "        else: res.append(f\"x={cp} (Chua ro)\")\n",
    "    print(f\"Cau 2{name}:\", \", \".join(res))\n",
    "\n",
    "ex2(3*x**4 - 16*x**3 + 18*x**2 - 9, 'a')\n",
    "ex2((x + 2)/(2*x**2), 'b')\n",
    "ex2(-x**2/3 + x**2 + 3*x + 4, 'c')\n",
    "ex2((5*x**2 + 5)/x, 'd')"
   ]
