    "draw_ex4(sp.sin(x), 0, float(sp.pi), 'g')\n",
    "draw_ex4(sp.sin(2*x), 0, 2, 'h')\n",
    "draw_ex4(sp.cos(x), float(sp.pi/2), float(3*sp.pi/2), 'i')\n",
